# ─── Python Runtime Artifacts ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
*.egg

# ─── Node / Frontend (Portability Mode) ───────────────────────────────────────
# node_modules/  → NOT ignored. Pushed for 100% clone-and-play portability.
dist/
build/
.next/
out/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── OS / System ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.suo
*.user

# ─── NOTE: The following are intentionally NOT ignored (portability law) ──────
# .meta_runtime/venv/.venv/  → master portable Python engine
# .meta_runtime/venv/.env    → master API secrets (PRIVATE REPO ONLY)
# .meta_runtime/auth/        → master session cookies (NotebookLM, etc.)
# .meta_runtime/.meta_scratch/ → ephemeral tool configs
# .meta_runtime/bin/         → portable binaries (ffmpeg, yt-dlp, etc.)
.meta_runtime/venv/.venv/
